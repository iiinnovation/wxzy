[
  {"type": "text", "text": "第九章 解表剂", "text_level": 1, "page_idx": 0},
  {"type": "text", "text": "白虎膏知甘粳镶,气分热盛此方良。", "page_idx": 0},
  {"type": "text", "text": "上五味,咬咀,以水七升。", "page_idx": 0},
  {"type": "text", "text": "遍身黎黎微似有汗者益佳。", "page_idx": 0},
  {"type": "text", "text": "学朝笔记混入正文不可忽略。", "page_idx": 0},
  {"type": "page_number", "text": "294", "page_idx": 0}
]
