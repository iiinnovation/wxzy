# Copy values to server runtime env or root .env.local. Never commit secrets.

# MinerU (local parse tools only)
MINERU_API_TOKEN=

# Optional Qwen / DashScope for candidate card generation
DASHSCOPE_API_KEY=
# DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# QWEN_MODEL=qwen-plus

# FastAPI
APP_ENV=development
AUTH_MODE=dev_token
API_TOKEN=dev-token-change-me
SESSION_TTL_SECONDS=2592000
# Production requires APP_ENV=production, AUTH_MODE=wechat and both values below.
WECHAT_APP_ID=
WECHAT_APP_SECRET=
# DATABASE_URL=sqlite+pysqlite:///./wxzy.db
# DATABASE_URL=postgresql+psycopg://wxzy:wxzy@127.0.0.1:5432/wxzy
CORS_ORIGINS=*
