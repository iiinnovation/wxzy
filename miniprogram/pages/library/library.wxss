.library-count {
  color: #5f6b76;
  background: #e8ecef;
  border-radius: 999rpx;
  padding: 8rpx 16rpx;
  font-size: 22rpx;
}

.library-intro {
  margin-bottom: 18rpx;
}

.intro-title {
  color: #17212b;
  font-size: 30rpx;
  font-weight: 700;
  margin-bottom: 4rpx;
}

.book-row,
.card-row {
  display: flex;
  align-items: center;
}

.book-row:active,
.card-item:active {
  background: #f3f8f7;
}

.book-mark {
  width: 58rpx;
  height: 70rpx;
  background: #284b63;
  border-radius: 4rpx 10rpx 10rpx 4rpx;
  color: #ffffff;
  font-size: 22rpx;
  line-height: 70rpx;
  text-align: center;
  margin-right: 18rpx;
  box-shadow: inset 6rpx 0 0 #bf5b45;
}

.book-main {
  flex: 1;
  min-width: 0;
}

.book-name {
  color: #17212b;
  font-size: 29rpx;
  font-weight: 600;
}

.book-toolbar {
  margin-bottom: 20rpx;
}

.back-link {
  color: #0f766e;
  font-size: 24rpx;
  padding: 4rpx 0 12rpx;
}

.active-book-title {
  color: #17212b;
  font-size: 38rpx;
  font-weight: 700;
}

.search-action {
  color: #0f766e;
  font-size: 25rpx;
  font-weight: 600;
  padding: 16rpx 4rpx 16rpx 18rpx;
}

.card-row {
  justify-content: space-between;
}

.card-chevron {
  transform: rotate(0deg);
  transition: transform 160ms ease;
}

.card-chevron.is-open {
  transform: rotate(90deg);
}

.library-answer {
  background: #f7faf9;
  border-left: 4rpx solid #0f766e;
  margin-top: 18rpx;
  padding: 16rpx 18rpx;
}

.answer-label {
  color: #0f766e;
  font-size: 22rpx;
  font-weight: 600;
  margin-bottom: 6rpx;
}

.answer-text {
  color: #17212b;
  font-size: 27rpx;
  line-height: 1.6;
  white-space: pre-wrap;
}

.source-text {
  color: #7a858f;
  border-top: 1rpx solid #e1e9e6;
  font-size: 22rpx;
  line-height: 1.5;
  margin-top: 14rpx;
  padding-top: 12rpx;
  white-space: pre-wrap;
}

.loading-note {
  color: #6b7280;
  font-size: 24rpx;
  text-align: center;
  padding: 28rpx;
}
