<view class="container">
  <view class="topbar">
    <view>
      <view class="eyebrow">应用与数据</view>
      <view class="page-title">我的</view>
    </view>
    <view class="connection-pill {{connectionState === '连接正常' ? 'is-online' : 'is-offline'}}">
      <text class="connection-dot"></text>
      <text>{{connectionState}}</text>
    </view>
  </view>

  <view class="settings-panel auth-panel">
    <view class="panel-heading">
      <view class="section-title">登录状态</view>
      <view class="muted">{{authStateLabel}}</view>
    </view>
    <view class="owner-row" wx:if="{{ownerName}}">
      <view class="label">当前 Owner</view>
      <view class="owner-name">{{ownerName}}</view>
    </view>
    <view class="muted" wx:else>尚未登录学习账户</view>

    <view class="auth-actions">
      <button
        class="btn btn-primary"
        bindtap="onWeChatLogin"
        loading="{{loggingIn}}"
        disabled="{{loggingIn || loggingOut}}"
      >
        微信登录
      </button>
      <button
        class="btn"
        bindtap="onLogout"
        loading="{{loggingOut}}"
        disabled="{{loggingIn || loggingOut}}"
      >
        退出登录
      </button>
    </view>
  </view>

  <view class="settings-panel profile-panel" wx:if="{{authState === 'ready'}}">
    <view class="panel-heading">
      <view class="section-title">学习档案</view>
      <view class="muted">{{needsOnboarding ? '尚未完成引导' : '已设置'}}</view>
    </view>
    <view class="profile-line"><text class="muted">目的</text><text>{{profileSummary.goalLabel}}</text></view>
    <view class="profile-line"><text class="muted">每日</text><text>{{profileSummary.minutesLabel}}</text></view>
    <view class="profile-line"><text class="muted">学习日</text><text>{{profileSummary.daysLabel}}</text></view>
    <view class="profile-line"><text class="muted">学科</text><text>{{profileSummary.subjectsLabel}}</text></view>
    <view class="auth-actions">
      <button class="btn btn-primary" bindtap="onOpenOnboarding" wx:if="{{needsOnboarding}}">完成引导</button>
      <button class="btn {{needsOnboarding ? 'btn-secondary' : 'btn-primary'}}" bindtap="onOpenProfileEdit">编辑档案</button>
    </view>
  </view>

  <view class="settings-panel" wx:if="{{showDevConfig}}">
    <view class="panel-heading">
      <view class="section-title">开发连接</view>
      <view class="muted">仅开发模式显示，生产版不暴露 Token</view>
    </view>

    <view class="label">API 地址</view>
    <input
      class="input"
      value="{{apiBase}}"
      bindinput="onApiBase"
      placeholder="http://127.0.0.1:8000"
    />

    <view class="field-heading">
      <view class="label token-label">开发 Token</view>
      <view class="token-toggle" bindtap="onToggleToken">{{showToken ? '隐藏' : '显示'}}</view>
    </view>
    <input
      class="input"
      value="{{token}}"
      bindinput="onToken"
      password="{{!showToken}}"
      placeholder="AUTH_MODE=dev_token 时使用"
    />

    <view class="error" wx:if="{{error}}">{{error}}</view>
    <view class="ok" wx:if="{{ok}}">{{ok}}</view>

    <button class="btn btn-primary save-button" bindtap="onSave" loading="{{saving}}" disabled="{{saving}}">
      保存并检测连接
    </button>
  </view>

  <view class="settings-panel" wx:else>
    <view class="panel-heading">
      <view class="section-title">服务连接</view>
      <view class="muted">生产模式使用微信 Session 鉴权</view>
    </view>
    <view class="error" wx:if="{{error}}">{{error}}</view>
    <view class="ok" wx:if="{{ok}}">{{ok}}</view>
    <view class="muted">API：{{apiBase}}</view>
  </view>

  <view class="section-header">
    <view class="section-title">学习概览</view>
    <view class="section-action" bindtap="onRefreshStats">刷新</view>
  </view>

  <view class="stats-panel">
    <view class="stat-primary">
      <view class="stat-large">{{stats.cards_approved || 0}}</view>
      <view class="muted">正式卡片</view>
    </view>
    <view class="stats-grid">
      <view class="stat-item">
        <view class="stat-value">{{stats.books || 0}}</view>
        <view class="metric-label">书籍</view>
      </view>
      <view class="stat-item">
        <view class="stat-value">{{stats.due_now || 0}}</view>
        <view class="metric-label">当前到期</view>
      </view>
      <view class="stat-item">
        <view class="stat-value">{{stats.reviewed_today || 0}}</view>
        <view class="metric-label">今日完成</view>
      </view>
      <view class="stat-item">
        <view class="stat-value">{{stats.new_cards || 0}}</view>
        <view class="metric-label">新卡</view>
      </view>
    </view>
  </view>

  <view class="privacy-note">
    Session 与开发 Token 仅保存在本机，不会上传到第三方。生产环境不展示或要求填写 API Token。
  </view>
</view>
