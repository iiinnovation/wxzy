.review-topbar {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  margin-bottom: 22rpx;
}

.review-count {
  color: #0f766e;
  background: #eaf7f1;
  border-radius: 999rpx;
  padding: 10rpx 16rpx;
  font-size: 23rpx;
}

.progress-track {
  height: 8rpx;
  background: #dfe7e7;
  border-radius: 8rpx;
  margin-bottom: 22rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: #0f766e;
  border-radius: 8rpx;
  transition: width 180ms ease;
}

.review-card {
  background: #ffffff;
  border: 1rpx solid #e1e6eb;
  border-radius: 10rpx;
  padding: 30rpx 28rpx;
  box-shadow: 0 8rpx 24rpx rgba(23, 33, 43, 0.05);
}

.review-meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-bottom: 1rpx solid #edf0f2;
  padding-bottom: 18rpx;
}

.book-label {
  color: #0f766e;
  font-size: 24rpx;
  font-weight: 600;
}

.question-label {
  color: #7a858f;
  font-size: 22rpx;
  margin-top: 28rpx;
}

.question {
  color: #17212b;
  font-size: 40rpx;
  font-weight: 700;
  line-height: 1.45;
  margin: 12rpx 0 30rpx;
  white-space: pre-wrap;
}

.recall-hint {
  display: flex;
  align-items: center;
  background: #f5f8f8;
  border-radius: 8rpx;
  padding: 20rpx;
  margin-bottom: 24rpx;
}

.recall-icon {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #dff1ed;
  color: #0f766e;
  font-size: 30rpx;
  line-height: 48rpx;
  text-align: center;
  margin-right: 16rpx;
}

.recall-title {
  color: #344054;
  font-size: 26rpx;
  font-weight: 600;
}

.answer-box {
  background: #f7faf9;
  border-left: 6rpx solid #0f766e;
  padding: 20rpx;
  margin-bottom: 24rpx;
}

.answer-label {
  color: #0f766e;
  font-size: 23rpx;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.answer {
  color: #17212b;
  font-size: 30rpx;
  line-height: 1.6;
  white-space: pre-wrap;
}

.answer-points {
  margin-top: 16rpx;
  border-top: 1rpx solid #dfeae6;
  padding-top: 12rpx;
}

.point {
  color: #344054;
  display: flex;
  font-size: 25rpx;
  line-height: 1.6;
}

.point-mark {
  color: #0f766e;
  padding-right: 10rpx;
}

.excerpt {
  color: #7a858f;
  font-size: 23rpx;
  line-height: 1.5;
  margin-top: 16rpx;
  white-space: pre-wrap;
}

.reveal-button {
  margin-top: 8rpx;
}

.rate-section {
  border-top: 1rpx solid #edf0f2;
  padding-top: 22rpx;
}

.rate-title {
  color: #344054;
  font-size: 25rpx;
  margin-bottom: 14rpx;
}

.rate-grid {
  display: flex;
  flex-wrap: wrap;
  margin: 0 -6rpx;
}

.rate {
  width: calc(50% - 12rpx);
  box-sizing: border-box;
  border-radius: 8rpx;
  color: #ffffff;
  margin: 6rpx;
  padding: 14rpx 0;
  line-height: 1.25;
}

.rate-again { background: #b84a3b; }
.rate-hard { background: #b87528; }
.rate-good { background: #0f766e; }
.rate-easy { background: #3c6f9e; }

.rate-sub {
  display: block;
  font-size: 21rpx;
  opacity: 0.82;
  margin-top: 4rpx;
}

.rate[disabled] {
  opacity: 0.55;
}

.next-hint {
  color: #17664d;
  background: #edf8f2;
  border-radius: 8rpx;
  font-size: 23rpx;
  margin-top: 20rpx;
  padding: 12rpx 16rpx;
}

.review-loading {
  background: #ffffff;
  border-radius: 10rpx;
  padding: 32rpx 28rpx;
}

.loading-line {
  width: 64%;
  height: 28rpx;
  border-radius: 6rpx;
  background: #edf0f2;
  margin-bottom: 18rpx;
}

.loading-wide {
  width: 90%;
  height: 44rpx;
}

.empty-button {
  margin-top: 28rpx;
}
